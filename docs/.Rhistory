dbExecute(con, "INSERT OR IGNORE INTO data_privacy_notices
(notice_id, version, title_en, title_ar, content_en, content_ar,
effective_from, is_active, requires_reconsent, published_by) VALUES
(1,
'v1.0 — February 2026',
'Data Privacy & Protection Notice — OBF Compliance Platform',
'\u0625\u0634\u0639\u0627\u0631 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a',
'This platform collects and processes institutional KPI data in accordance with:\n\n• UAE Federal Decree-Law No. 45 of 2021 on Personal Data Protection (PDPL)\n• MoHESR OBF Framework v11.5 (23 March 2026)\n• ADHA-Les Roches Data Governance Policy\n\nDATA COLLECTED: KPI values, supporting evidence metadata, user activity logs, and audit trail records. No personal student data is collected directly by this platform.\n\nDATA USE: Solely for OBF compliance reporting to MoHESR via the Higher Education Database (HEDB). Data is not shared with third parties outside MoHESR regulatory reporting obligations.\n\nDATA RETENTION: KPI submission data is retained for 7 years per MoHESR archiving requirements. Audit logs are retained for 5 years.\n\nYOUR RIGHTS: Under UAE PDPL Article 6, you may request access to, correction of, or restriction of data processed about your platform activity. Contact: dpo@adha.ae\n\nBy clicking ''I Agree'' you confirm that you have read, understood, and consent to the processing of institutional data as described above in your capacity as an authorised OBF platform user.',
'\u062a\u062c\u0645\u0639 \u0647\u0630\u0647 \u0627\u0644\u0645\u0646\u0635\u0629 \u0628\u064a\u0627\u0646\u0627\u062a \u0645\u0624\u0634\u0631\u0627\u062a \u0627\u0644\u0623\u062f\u0627\u0621 \u0648\u062a\u0639\u0627\u0644\u062c\u0647\u0627 \u0648\u0641\u0642\u0627\u064b \u0644\u0644\u0648\u0627\u0626\u062d UAE PDPL \u0648\u0625\u0637\u0627\u0631 OBF.',
'2026-02-01', 1, 0, 'system')")
cat("  [SEEDED] data_privacy_notices — v1.0 PDPL notice\n")
cat("\nAll reference data seeded.\n\n")
}
