# ==============================================================================
#  SECTION 5 -- SAMPLE KPI DATA (for platform testing)
# ==============================================================================
add_adha_sample_data <- function(con) {
cat(">> Checking sample data...\n")
n <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpi_data")$n
if (n > 300) {
cat("   Sample data already present (", n, "records) -- skipping.\n")
return(invisible(NULL))
}
cat(">> Generating ADHA sample KPI data (5 periods x 24 KPIs x 3 colleges + institution)...\n")
kpis    <- dbGetQuery(con, "SELECT kpi_id, kpi_code, unit FROM kpis ORDER BY kpi_id")
colleges <- c(1L)   # HM (Hospitality Management)
# College-level base values (ADHA-calibrated)
base_college <- c(
"1"=85,  "2"=75,  "3"=80,  "4"=85,  "5"=3.8, "6"=3.9,
"7"=65,  "8"=4.0, "9"=60,  "10"=70, "11"=40, "12"=400000,
"13"=150, "14"=1.2, "15"=20, "16"=35, "17"=6,  "18"=3,
"19"=450, "20"=90, "21"=15, "22"=25, "23"=40, "24"=22
)
# Institution-level base values (slightly higher than college aggregate)
base_inst <- c(
"1"=88,  "2"=78,  "3"=83,  "4"=88,  "5"=4.0, "6"=4.1,
"7"=68,  "8"=4.2, "9"=65,  "10"=73, "11"=42, "12"=420000,
"13"=165, "14"=1.3, "15"=22, "16"=38, "17"=7,  "18"=4,
"19"=450, "20"=92, "21"=18, "22"=28, "23"=42, "24"=25
)
fmt_val <- function(val, unit) switch(unit,
"Percentage"  = pmin(pmax(round(val, 1), 0), 100),
"Score (1-5)" = pmin(pmax(round(val, 1), 1), 5),
"AED"         = round(val, -3),
"Index"       = round(val, 2),
round(val, 0))
set.seed(42)   # reproducible sample data
rows_added <- 0L
for (pid in 1:5) {
trend <- 1 + (pid - 1) * 0.015   # +1.5% improvement per period
for (ki in seq_len(nrow(kpis))) {
kpi    <- kpis[ki, ]
kid    <- as.character(kpi$kpi_id)
b_coll <- as.numeric(base_college[kid]) %||% 50
b_inst <- as.numeric(base_inst[kid])    %||% 55
# College-level (one row per ADHA college)
for (college in colleges) {
cv <- fmt_val(b_coll * trend * runif(1, 0.88, 1.12), kpi$unit)
tryCatch(dbExecute(con,
"INSERT OR IGNORE INTO kpi_data
(kpi_id, period_id, college_id, program_id, value,
entered_by, validation_status, notes, entry_date)
VALUES (?,?,?,NULL,?,'system','Approved','ADHA sample college data',datetime('now'))",
params = list(kpi$kpi_id, pid, college, cv)), error = function(e) NULL)
rows_added <- rows_added + 1L
}
# Institution-level (college_id = NULL)
iv <- fmt_val(b_inst * trend, kpi$unit)
tryCatch(dbExecute(con,
"INSERT OR IGNORE INTO kpi_data
(kpi_id, period_id, college_id, program_id, value,
entered_by, validation_status, notes, entry_date)
VALUES (?,?,NULL,NULL,?,'system','Approved','ADHA sample institution data',datetime('now'))",
params = list(kpi$kpi_id, pid, iv)), error = function(e) NULL)
rows_added <- rows_added + 1L
}
}
final_rows <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpi_data")$n
cat(sprintf("  %d rows inserted (%d total, all Approved) [OK]\n\n", rows_added, final_rows))
}
# ==============================================================================
#  SECTION 6 -- POST-SEED UPDATES
# ==============================================================================
post_adha_updates <- function(con) {
cat(">> Applying rolling-average and inversion flags...\n")
tryCatch({
# P1 (Employment Outcomes) + P6 (Community Engagement) = 3-year rolling
dbExecute(con, "UPDATE kpis SET rolling_avg_years = 3 WHERE kpi_code IN ('1.1','1.2','6.1','6.2')")
# P4 (Research Outcomes) = 5-year rolling (per OBF v11 Guidebook)
dbExecute(con, "UPDATE kpis SET rolling_avg_years = 5 WHERE kpi_code IN ('4.1','4.2','4.3','4.4','4.5','4.6')")
# KPI 5.1 (Rankings) is inverted: lower rank number = better performance
dbExecute(con, "UPDATE kpis SET is_inverted = 1 WHERE kpi_code = '5.1'")
cat("  P1/P6 = 3yr rolling | P4 = 5yr rolling | KPI 5.1 inverted  [OK]\n")
}, error = function(e) cat("  Note:", e$message, "\n"))
# Backfill retention_until for any evidence rows inserted without trigger
tryCatch(
dbExecute(con,
"UPDATE evidence_documents
SET retention_until = date(upload_date, '+7 years')
WHERE retention_until IS NULL"),
error = function(e) NULL)
# Backfill: expire any already-overdue delegations
tryCatch({
expired_n <- dbExecute(con,
"UPDATE user_delegations SET status = 'Expired'
WHERE valid_until < date('now') AND status = 'Active'")
cat(sprintf("  [BACKFILL] %d stale delegation(s) expired\n", expired_n))
}, error = function(e) NULL)
cat("\n")
}
# ==============================================================================
#  SECTION 7 -- AUTHENTICATION DATABASE (shinymanager)
# ==============================================================================
initialize_adha_auth_database <- function() {
cat(">> Phase 2: Initialising authentication database...\n")
# Check if shinymanager is available
if (!requireNamespace("shinymanager", quietly = TRUE)) {
cat("   Installing shinymanager package...\n")
install.packages("shinymanager")
}
library(shinymanager)
if (file.exists(ADHA_AUTH_PATH)) {
cat("   Auth DB already exists — removing for fresh init...\n")
file.remove(ADHA_AUTH_PATH)
}
# Plain-text passwords — create_db() auto-hashes via scrypt.
# These MUST exactly match the passwords in app_adha.r's credentials df.
adha_credentials <- data.frame(
user = c(
"adha.admin",  #  1  System Administrator
"mohesr_user",  #  2  MoHESR Officer
"georgette.davey",  #  3  Georgette Davey (President/Rector)
"univ.admin",  #  4  ADHA-Les Roches University Admin
"adhales.chair",  #  5  ADHA-Les Roches QA Chair (University QA Chair)
"prof..richardson",  #  6  Prof. Scott Richardson (Dean, HM)
"qa.hm",  #  7  Hospitality Management QA Chair
"data.entry",  #  8  ADHA-Les Roches Data Entry Officer
"viewer"   #  9  ADHA-Les Roches Viewer
),
password = c(
"ADHA@Admin2026!",  # adha.admin
"ChangeMe!MoHESR2026",  # mohesr_user
"ADHA@Pres2026!",  # georgette.davey
"ADHA@VP2026!",  # univ.admin
"ADHA@UQA2026!",  # adhales.chair
"ADHA@Dean2026!",  # prof..richardson
"ADHA@Dean2026!",  # qa.hm
"ADHA@DE2026!",  # data.entry
"Viewer@2026!"   # viewer
),
admin  = c(TRUE, FALSE, FALSE, FALSE, FALSE, FALSE, FALSE, FALSE, FALSE),
start  = rep("2026-01-01", 9),
expire = rep("2030-12-31", 9),
stringsAsFactors = FALSE
)
cat("   Creating shinymanager auth DB with", nrow(adha_credentials), "ADHA users...\n")
tryCatch(
shinymanager::create_db(
credentials_data = adha_credentials,
sqlite_path      = ADHA_AUTH_PATH,
passphrase       = ADHA_AUTH_PASSPHRASE
),
error = function(e) cat("ERROR creating auth DB:", e$message, "\n")
)
if (file.exists(ADHA_AUTH_PATH)) {
cat("   Auth DB created successfully at:", ADHA_AUTH_PATH, "\n\n")
} else {
cat("   WARNING: Auth DB may not have been created properly.\n\n")
}
invisible(TRUE)
}
# ==============================================================================
#  SECTION 8 -- VALIDATION CHECKS
# ==============================================================================
validate_adha_database <- function(con) {
cat(">> Running validation checks...\n")
chk <- function(ok) if (ok) "\u2713 PASS" else "\u2717 FAIL"
p_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM obf_pillars")$n
k_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpis")$n
k_dist <- dbGetQuery(con, "SELECT pillar_id, COUNT(*) AS kc FROM kpis GROUP BY pillar_id ORDER BY pillar_id")
tw     <- round(dbGetQuery(con, "SELECT SUM(weight) AS t FROM obf_pillars")$t, 1)
inv_n  <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpis WHERE is_inverted=1")$n
rav_n  <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpis WHERE rolling_avg_years>0")$n
col_n  <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM colleges")$n
prg_n  <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM programs")$n
u_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM users")$n
r_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM roles")$n
per_n  <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM reporting_periods")$n
kv_n   <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpi_versions")$n
d_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpi_data")$n
a_n    <- dbGetQuery(con, "SELECT COUNT(*) AS n FROM kpi_data WHERE validation_status='Approved'")$n
cm_n   <- tryCatch(dbGetQuery(con, "SELECT COUNT(*) AS n FROM committee_members")$n, error = function(e) 0)
deleg_n<- tryCatch(dbGetQuery(con, "SELECT COUNT(*) AS n FROM user_delegations")$n,  error = function(e) 0)
board_n<- tryCatch(dbGetQuery(con, "SELECT COUNT(*) AS n FROM board_of_trustees")$n, error = function(e) 0)
trig_n <- nrow(dbGetQuery(con, "SELECT name FROM sqlite_master WHERE type='trigger'"))
idx_n  <- nrow(dbGetQuery(con, "SELECT name FROM sqlite_master WHERE type='index'"))
tbl_n  <- length(dbListTables(con))
mfa_cols_ok <- tryCatch({
cols <- dbGetQuery(con, "PRAGMA table_info(users)")$name
all(c("mfa_enabled","mfa_secret","mfa_failed_attempts","mfa_locked_until") %in% cols)
}, error = function(e) FALSE)
deleg_cols_ok <- tryCatch({
cols <- dbGetQuery(con, "PRAGMA table_info(user_delegations)")$name
all(c("notification_sent","status","valid_from","valid_until") %in% cols)
}, error = function(e) FALSE)
# ADHA KPI distribution: P1=2, P2=6, P3=4, P4=6, P5=4, P6=2
dist_ok <- length(k_dist$kc) == 6 && all(k_dist$kc == c(2, 6, 4, 6, 4, 2))
cat(sprintf("  Pillars              : %2d  %s\n", p_n,   chk(p_n == 6)))
cat(sprintf("  KPIs                 : %2d  %s  (Distribution: %s)\n", k_n, chk(k_n == 24), paste(k_dist$kc, collapse = "-")))
cat(sprintf("  KPI Dist 2-6-4-6-4-2 :     %s\n", chk(dist_ok)))
cat(sprintf("  Total Pillar Weight  : %s%%  %s  (ADHA: 30/25/15/10/15/5)\n", tw, chk(abs(tw - 100) < 0.1)))
cat(sprintf("  Rolling Avg KPIs     : %2d  %s  (expected 10: KPI 1.1,1.2 + 4.1-4.6 + 6.1,6.2)\n", rav_n, chk(rav_n == 10)))
cat(sprintf("  Inverted KPIs        :  %d  %s  (KPI 5.1 — lower rank = better)\n", inv_n, chk(inv_n == 1)))
cat(sprintf("  Colleges             :  %d  %s  (HM)\n", col_n, chk(col_n == 1)))
cat(sprintf("  Programs             : %2d  %s  (1 Bachelor / 2 Master / 0 PhD)\n", prg_n, chk(prg_n == 3)))
cat(sprintf("  Users                : %2d  %s\n", u_n, chk(u_n == 9)))
cat(sprintf("  Roles                :  %d  %s\n", r_n, chk(r_n == 9)))
cat(sprintf("  Periods              :  %d  %s  (Semester-based: 2023-24 → 2025-26)\n", per_n, chk(per_n == 5)))
cat(sprintf("  KPI Versions         : %2d  %s\n", kv_n, chk(kv_n == 24)))
cat(sprintf("  KPI Data Rows        : %4d (incl. %d Approved)\n", d_n, a_n))
cat(sprintf("  Committee Members    : %2d  %s\n", cm_n, chk(cm_n == 3)))
cat(sprintf("  Board of Trustees    : %2d  %s\n", board_n, chk(board_n == 1)))
cat(sprintf("  MFA Columns          :     %s\n", chk(mfa_cols_ok)))
cat(sprintf("  Deleg. Columns       :     %s\n", chk(deleg_cols_ok)))
cat(sprintf("  Triggers             :  %d\n", trig_n))
cat(sprintf("  Indexes              : %2d\n", idx_n))
cat(sprintf("  Total Tables         : %2d\n", tbl_n))
cat("\n")
invisible(list(
colleges_ok = col_n == 1,
programs_ok = prg_n == 3,
users_ok = u_n == 9,
pillars_ok = p_n == 6,
kpis_ok = k_n == 24,
weights_ok = abs(tw - 100) < 0.1,
mfa_cols_ok = mfa_cols_ok,
deleg_cols_ok = deleg_cols_ok
))
}
# ==============================================================================
#  SECTION 9 -- MAIN EXECUTION
# ==============================================================================
main <- function() {
cat("\n>> Phase 1: Initialising operational database...\n")
tryCatch({
con <- initialize_adha_database()  # creates tables & disconnects internally
# Re-open for seeding
con <- dbConnect(RSQLite::SQLite(), ADHA_DB_PATH)
dbExecute(con, "PRAGMA foreign_keys = ON")
on.exit({ dbDisconnect(con); cat("\nConnection closed.\n") }, add = TRUE)
seed_adha_data(con)
seed_adha_governance(con)
seed_adha_board(con)
add_adha_sample_data(con)
post_adha_updates(con)
validation <- validate_adha_database(con)
all_pass <- validation$pillars_ok && validation$kpis_ok &&
validation$weights_ok && validation$colleges_ok &&
validation$programs_ok && validation$users_ok &&
validation$mfa_cols_ok && validation$deleg_cols_ok
}, error = function(e) {
cat("ERROR in operational DB:", conditionMessage(e), "\n")
stop(e)
})
cat("\n>> Phase 2: Initialising authentication database...\n")
initialize_adha_auth_database()
cat("\n=================================================================\n")
cat(" ADHA OBF DATABASE INITIALISATION COMPLETE\n")
cat("=================================================================\n")
cat(" Operational DB :", ADHA_DB_PATH, "\n")
cat(" Auth DB        :", ADHA_AUTH_PATH, "\n")
cat(" Institution    :", ADHA_INST_NAME_EN, "\n")
cat(" Brand          :", ADHA_BRAND_PRIMARY, "\n")
cat(" Logo file      :", ADHA_LOGO_FILE, "\n")
cat(" Colleges       : 1 (HM)\n")
cat(" Programs       : 3 (1 Bachelor / 2 Master / 0 PhD)\n")
cat(" Users seeded   : 9 (all must_change_password = TRUE except adha.admin + mohesr_user)
")
cat(" Committees     : 3 with 3 members (generic)\n")
cat(" Board trustees : 1
")
cat(" Pillar weights : 30/25/15/10/15/5%
")
cat("-----------------------------------------------------------------\n")
if (all_pass) {
cat(" ✅ ALL VALIDATION CHECKS PASSED — ADHA OBF Platform ready for launch\n")
} else {
cat(" ⚠ ONE OR MORE CHECKS FAILED — review output above\n")
}
cat("=================================================================\n")
cat("Launch app_adha.r to start the ADHA OBF platform.\n")
cat("\n")
cat("Default login credentials:\n")
cat("  adha.admin                      ADHA@Admin2026!                      (must_change_password = FALSE)\n")
cat("  mohesr_user                     ChangeMe!MoHESR2026                  (must_change_password = FALSE)\n")
cat("  georgette.davey                 ADHA@Pres2026!                       (must change on first login)\n")
cat("  univ.admin                      ADHA@VP2026!                         (must change on first login)\n")
cat("  adhales.chair                   ADHA@UQA2026!                        (must change on first login)\n")
cat("  prof..richardson                ADHA@Dean2026!                       (must change on first login)\n")
cat("\n")
cat("PENDING (resolve before MoHESR go-live):\n")
cat("  [TBC_HEDB_INSTITUTION_ID] Obtain from MoHESR HEDB portal\n")
cat("  [TBC_CAA_LICENCE_NUMBER]  Obtain from caa.ae > Institutions > ADHA\n")
cat("  SMTP password             Configure in Admin > API Configuration\n")
cat("\n")
cat("NOTE: The shinymanager auth DB (", ADHA_AUTH_PATH, ") is created automatically\n")
cat("      by this script. Run the app once, then log in with\n")
cat("      the credentials above. Password changes via the platform are\n")
cat("      synced to the auth DB automatically (scrypt hashing).\n")
cat("=================================================================\n")
}
main()
